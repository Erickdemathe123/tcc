# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env

# Segurança — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-forte

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://agrobanana:senha@localhost:5432/agrobanana

# E-mail (Gmail como exemplo)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app-gmail
MAIL_DEFAULT_SENDER=seu-email@gmail.com
